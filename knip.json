{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/core": {
      "entry": ["tests/**/*.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/platform": {
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": [
        "src/app/App.tsx",
        "src/pages/**/*.tsx",
        "src/**/*.test.{ts,tsx}",
        "scripts/**/*.{ts,js}"
      ],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{ts,js}"],
      "ignore": ["**/testing/**"],
      "paths": {
        "@/*": ["src/*"]
      }
    }
  },
  "ignoreDependencies": [
    "@axe-core/playwright",
    "@playwright/test",
    "@commitlint/cli",
    "dotenv",
    "prettier-plugin-tailwindcss"
  ],
  "ignoreBinaries": ["pre-commit", "tsc"],
  "ignoreExportsUsedInFile": true,
  "ignore": ["tools/**"]
}
