<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <color name="brand_primary">#1DB954</color>
    <color name="brand_primary_dark">#1ED760</color>
    <color name="surface_dark">#0F0F0F</color>
    <color name="surface_light">#1E1E1E</color>
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#BABABA</color>
    <color name="text_tertiary">#909090</color>
    <color name="text_on_accent">#000000</color>
    <color name="input_bg">#1A1A1A</color>
    <color name="input_border">#333333</color>

    <style name="Theme.YayTsa" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:editTextColor">@color/text_primary</item>
    </style>

    <style name="Theme.YayTsa.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
