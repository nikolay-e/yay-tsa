# Yay-Tsa Configuration
# Copy this file to .env and set the required values.

# ============================================================
# REQUIRED
# ============================================================

# Path to your music library on the host machine
MEDIA_PATH=/path/to/your/music

# Admin password (change this!)
ADMIN_PASSWORD=changeme

# Database password (change this!)
DB_PASSWORD=changeme

# ============================================================
# OPTIONAL
# ============================================================

# Port to access Yay-Tsa (default: 3000)
# PORT=3000

# Pin to a specific version (e.g., "main-920d68f" or "latest")
# APP_VERSION=latest

# Admin username (default: admin)
# ADMIN_USERNAME=admin

# Scan music library on startup (default: true)
# SCAN_ON_STARTUP=true

# CORS origins — set to your public URL if deploying on a real domain
# CORS_ORIGINS=https://music.example.com

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ============================================================
# KARAOKE (optional, requires --profile karaoke)
# ============================================================

# Device for vocal separation: cpu or cuda (default: cpu)
# KARAOKE_DEVICE=cpu

# ============================================================
# METADATA PROVIDERS (optional, improves library metadata)
# ============================================================

# GENIUS_ACCESS_TOKEN=
# LASTFM_API_KEY=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# ACOUSTID_API_KEY=
