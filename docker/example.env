# Yay-Tsa Configuration
# Copy this file to .env and set the required values.

# ============================================================
# REQUIRED — set these before `docker compose up`
# ============================================================

# Admin password for the first user (REQUIRED — change this!)
ADMIN_PASSWORD=changeme

# Database password (REQUIRED — change this!)
DB_PASSWORD=changeme

# ============================================================
# OPTIONAL
# ============================================================

# Path to your music library on the host. Defaults to ./music (created empty) so the
# stack boots without music; point it at your library to scan real files.
# MEDIA_PATH=/path/to/your/music

# Port to access Yay-Tsa (default: 3000)
# PORT=3000

# Pin to a specific version (e.g., "main-920d68f" or "latest")
# APP_VERSION=latest

# Admin username (default: admin)
# ADMIN_USERNAME=admin

# CORS origins — set to your public URL if deploying on a real domain
# CORS_ORIGINS=https://music.example.com

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ============================================================
# KARAOKE (optional, requires --profile karaoke)
# ============================================================

# Required in addition to `--profile karaoke` — the profile only starts the
# separator container; this flag makes the backend use it.
# KARAOKE_ENABLED=true

# Device for vocal separation: cpu or cuda (default: cpu)
# KARAOKE_DEVICE=cpu
