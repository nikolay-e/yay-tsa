{
  "name": "yay-tsa",
  "version": "0.0.0-placeholder",
  "private": true,
  "description": "Yay-Tsa - A minimal music player",
  "keywords": [
    "yay-tsa",
    "music",
    "player",
    "audio"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/platform && cd apps/web && npm run build",
    "build:core": "cd packages/core && npm run build",
    "build:platform": "cd packages/platform && npm run build",
    "check:bundle": "bundlewatch",
    "check:circular": "madge --circular --extensions ts packages/",
    "check:duplication": "jscpd .",
    "check:lighthouse": "npm run build && lhci autorun",
    "check:types": "type-coverage --at-least 90 --ignore-catch",
    "check:unused": "knip --no-progress",
    "dev": "tsc -b packages/core packages/platform && cd apps/web && npm run dev",
    "format": "prettier --write .",
    "generate:splash": "node scripts/generate-splash-screens.js",
    "lint": "prettier --check .",
    "pre-commit": "pre-commit run --all-files",
    "prepare": "command -v pre-commit >/dev/null 2>&1 && (pre-commit install && pre-commit install --hook-type commit-msg) || true",
    "sync:version": "node scripts/sync-version.js",
    "type-check": "tsc -b packages/core packages/platform && cd apps/web && npx tsc --noEmit",
    "postversion": "npm run sync:version"
  },
  "overrides": {
    "lodash": "4.17.23",
    "serialize-javascript": ">=7.0.3",
    "tmp": "0.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.57.0",
    "bundlewatch": "^0.4.1",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "jsdom": "^29.0.2",
    "knip": "^6.3.1",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "type-coverage": "^2.29.7",
    "vitest": "^4.1.4",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
