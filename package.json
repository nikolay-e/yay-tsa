{
  "name": "yay-tsa",
  "version": "0.0.0-placeholder",
  "private": true,
  "description": "Yay-Tsa - A minimal music player",
  "keywords": [
    "yay-tsa",
    "music",
    "player",
    "audio"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run gen:constants && tsc -b packages/core packages/platform && cd apps/web && npm run build",
    "build:core": "npm run gen:constants && cd packages/core && npm run build",
    "build:platform": "cd packages/platform && npm run build",
    "check:bundle": "bundlewatch",
    "check:duplication": "jscpd .",
    "check:lighthouse": "npm run build && lhci autorun",
    "check:types": "type-coverage --at-least 90 --ignore-catch",
    "check:unused": "knip --no-progress",
    "dev": "npm run gen:constants && tsc -b packages/core packages/platform && cd apps/web && npm run dev",
    "format": "prettier --write .",
    "gen:constants": "node scripts/gen-constants.mjs",
    "lint": "prettier --check .",
    "lint:js": "eslint packages/core/src packages/platform/src apps/web/src",
    "pre-commit": "pre-commit run --all-files",
    "prepare": "command -v pre-commit >/dev/null 2>&1 && (pre-commit install && pre-commit install --hook-type commit-msg) || true",
    "profile:bundle": "node scripts/bundle-report.mjs",
    "profile:bundle:build": "npm run build && node scripts/bundle-report.mjs",
    "profile:images": "node scripts/profile-images.mjs",
    "profile:web": "node scripts/profile-web.mjs",
    "test": "npm run test:unit --workspace=packages/core && npm run test --workspace=packages/platform && npm run test --workspace=apps/web",
    "type-check": "npm run gen:constants && tsc -b packages/core packages/platform && cd apps/web && npx tsc --noEmit"
  },
  "overrides": {
    "@babel/core": ">=7.29.6",
    "axios": ">=1.13.0",
    "lodash": "4.18.1",
    "serialize-javascript": ">=7.0.3",
    "tmp": "0.2.7",
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.5",
    "@lhci/cli": "^0.15.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.57.0",
    "bundlewatch": "^0.4.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jscpd": "^5.0.12",
    "knip": "^6.26.0",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "type-coverage": "^2.29.7",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
